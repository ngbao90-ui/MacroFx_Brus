name: Daily FX Dashboard Update

on:
  schedule:
    # 23:00 UTC = 06:00 Asia/Ho_Chi_Minh (UTC+7), every day
    - cron: '0 23 * * *'
  workflow_dispatch:
    inputs:
      llm_provider:
        description: 'Override LLM provider for this run (anthropic / deepseek / openrouter / openai_compatible)'
        required: false
        type: string
      enable_web_search:
        description: 'Force-enable web search this run (true/false)'
        required: false
        type: string

permissions:
  contents: write

concurrency:
  group: dashboard-update
  cancel-in-progress: false

jobs:
  update:
    runs-on: ubuntu-latest
    env:
      # ---- choose your LLM provider here, or override per-run via workflow_dispatch ----
      LLM_PROVIDER: ${{ inputs.llm_provider || vars.LLM_PROVIDER || 'anthropic' }}
      LLM_MODEL: ${{ vars.LLM_MODEL }}
      ENABLE_WEB_SEARCH: ${{ inputs.enable_web_search || vars.ENABLE_WEB_SEARCH || 'false' }}
      # ---- secrets (set in Settings -> Secrets and variables -> Actions) ----
      ANTHROPIC_API_KEY: ${{ secrets.ANTHROPIC_API_KEY }}
      DEEPSEEK_API_KEY: ${{ secrets.DEEPSEEK_API_KEY }}
      OPENROUTER_API_KEY: ${{ secrets.OPENROUTER_API_KEY }}
      OPENAI_COMPATIBLE_API_KEY: ${{ secrets.OPENAI_COMPATIBLE_API_KEY }}
      OPENAI_COMPATIBLE_BASE_URL: ${{ vars.OPENAI_COMPATIBLE_BASE_URL }}
      OPENAI_COMPATIBLE_MODEL: ${{ vars.OPENAI_COMPATIBLE_MODEL }}
      FMP_API_KEY: ${{ secrets.FMP_API_KEY }}
      TELEGRAM_BOT_TOKEN: ${{ secrets.TELEGRAM_BOT_TOKEN }}
      TELEGRAM_CHAT_ID: ${{ secrets.TELEGRAM_CHAT_ID }}

    steps:
      - name: Checkout
        uses: actions/checkout@v4

      - name: Setup Node
        uses: actions/setup-node@v4
        with:
          node-version: '20'

      - name: Install dependencies
        run: npm ci

      - name: 1) Fetch live market prices (FMP, no LLM cost)
        run: npm run fetch-market

      - name: 2) LLM update (JSON patch only, cheap)
        run: npm run llm-update

      - name: 3) Render static HTML from JSON
        run: npm run render

      - name: 4) Swing detector -> Telegram alert
        run: npm run swing-detect

      - name: Commit & push updated data + site
        run: |
          git config user.name "fx-dashboard-bot"
          git config user.email "actions@users.noreply.github.com"
          git add data/dashboard.json data/alert-state.json docs/index.html
          if git diff --cached --quiet; then
            echo "No changes to commit."
          else
            git commit -m "Auto update dashboard $(date -u +'%Y-%m-%d %H:%M UTC')"
            git push
          fi
